@page "/genre/{genreName}"
@implements IAsyncDisposable
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<BookstoreDb> DbFactory
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Bookstore - Genre - @GenreName</PageTitle>

<h1>Genre: @GenreName</h1>

@if (books is null)
{
    <p>Loading...</p>
}
else
{
    <div class="card">
        <div class="card-body p-0">
            @foreach (var book in books)
            {
                <div class="d-flex justify-content-between align-items-center px-3 py-3 border-bottom">
                    <div>
                        <a href="@GetBookDetailsLink(book.Id)" class="fs-4 text-decoration-none">@book.Title</a>
                        <div class="text-body-secondary">@book.Author</div>
                    </div>
                    <div class="fw-bold fs-5">@GetPrice(book.Price)</div>
                </div>
            }
        </div>
    </div>
}

<div class="mt-3">
    <a href="/">Back to Home</a>
</div>

@code {
    [Parameter]
    public string GenreName { get; set; } = string.Empty;

    private BookstoreDb context = default!;
    private List<Book>? books;

    protected override void OnInitialized()
    {
        context = DbFactory.CreateDbContext();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrWhiteSpace(GenreName))
        {
            NavigationManager.NotFound();
            return;
        }

        books = await context.Books
            .AsNoTracking()
            .Where(book => book.Genre == GenreName)
            .OrderBy(book => book.Title)
            .ToListAsync();

        if (books.Count == 0)
        {
            NavigationManager.NotFound();
        }
    }

    public async ValueTask DisposeAsync() => await context.DisposeAsync();

    private static string GetBookDetailsLink(int bookId) => $"/books/details?id={bookId}";

    private static string GetPrice(decimal price) => $"${price:0.00}";
}
