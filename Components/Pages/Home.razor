@page "/"
@implements IAsyncDisposable
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<BookstoreDb> DbFactory
@rendermode InteractiveServer

<PageTitle>Bookstore - Home</PageTitle>

<div class="row mt-5 mx-auto">
    <div class="col-sm-2 border pt-3 me-3 mb-3">
        <a href="/books/create" class="btn btn-primary">New Book</a>
        <div class="mt-3">
            <h6>Filter by:</h6>
            <select class="form-control" @bind="genreFilter">
                <option value="">Genre</option>
                @foreach (var genre in genres)
                {
                        <option value="@genre">@genre</option>
                }
            </select>
        </div>
        <div class="mt-3">
            <h6>Sort by price:</h6>
            <select class="form-control" @bind="priceSort">
                <option value="">No sorting</option>
                <option value="asc">Lowest to highest</option>
                <option value="desc">Highest to lowest</option>
            </select>
        </div>
    </div>

    <div class="col">
        @if (books.Count == 0)
        {
            <p>Loading...</p>
        }
        else
        {
            <div class="hstack flex-wrap gap-3">
                @foreach (var book in DisplayedBooks)
                {
                    <BookCard Book="@book" />
                }
            </div>
        }
    </div>
</div>


@code {
    private BookstoreDb context = default!;

    private List<Book> books = [];

    private string genreFilter = string.Empty;
    private string priceSort = string.Empty;

    private IEnumerable<Book> FilteredBooks =>
        books.Where(b => string.IsNullOrWhiteSpace(genreFilter) || b.Genre == genreFilter);

    private IEnumerable<Book> DisplayedBooks => priceSort switch
    {
        "asc" => FilteredBooks.OrderBy(b => b.Price),
        "desc" => FilteredBooks.OrderByDescending(b => b.Price),
        _ => FilteredBooks
    };

    private IEnumerable<string> genres =>
        books.Select(b => b.Genre)
            .Where(g => !string.IsNullOrWhiteSpace(g))
            .Distinct()
            .OrderBy(g => g);

    protected override void OnInitialized()
    {
        context = DbFactory.CreateDbContext();
        books = context.Books.AsNoTracking().ToList();
    }

    public async ValueTask DisposeAsync() => await context.DisposeAsync();
}
