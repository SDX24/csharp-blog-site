@page "/myorders"
@implements IAsyncDisposable
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<BookstoreDb> DbFactory
@rendermode InteractiveServer

<PageTitle>Bookstore - My Orders</PageTitle>

<h1>My Orders</h1>

@if (orders is null)
{
    <p>Loading...</p>
}
else if (!orders.Any())
{
    <p>No orders have been placed yet.</p>
}
else
{
    @foreach (var order in orders)
    {
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span class="fs-4">Order #@order.Id</span>
                <span class="fs-4">@order.OrderDate.ToString("MMMM dd, yyyy")</span>
            </div>
            <div class="card-body">
                @foreach (var item in order.OrderItems)
                {
                    <div class="d-flex justify-content-between align-items-center mb-2 fs-4">
                        <span>@GetItemLabel(item)</span>
                        <span>@GetItemPrice(item)</span>
                    </div>
                }

                <hr />

                <div class="d-flex justify-content-between align-items-center fw-bold fs-3">
                    <span>Total:</span>
                    <span>@GetTotalPrice(order)</span>
                </div>
            </div>
        </div>
    }
}

@code {
    private BookstoreDb context = default!;
    private List<Order>? orders;

    protected override async Task OnInitializedAsync()
    {
        context = DbFactory.CreateDbContext();
        orders = await context.Orders
            .AsNoTracking()
            .Include(o => o.OrderItems)
            .ThenInclude(oi => oi.Book)
            .OrderByDescending(o => o.OrderDate)
            .ToListAsync();
    }

    public async ValueTask DisposeAsync() => await context.DisposeAsync();

    private static string GetItemLabel(OrderItem item)
    {
        var bookTitle = item.Book?.Title ?? "Unknown book";
        return $"{bookTitle} (x {item.Quantity})";
    }

    private static string GetItemPrice(OrderItem item)
    {
        if (item.Book is null)
        {
            return "$0.00";
        }

        return $"${item.GetTotal():0.00}";
    }

    private static string GetTotalPrice(Order order) => $"${order.GetTotal():0.00}";
}
