@page "/checkout"

@using Microsoft.EntityFrameworkCore
@implements IDisposable
@inject OrderState OrderState
@inject NavigationManager NavigationManager
@inject IDbContextFactory<BookstoreDb> DbFactory
@rendermode InteractiveServer

<PageTitle>Bookstore - Checkout</PageTitle>

<h1>Bookstore - Checkout</h1>

@if (Order.OrderItems.Any())
{
    <dl>
        @foreach(var item in Order.OrderItems)
        {
            <dt>@item.Book.Title (@item.Quantity)</dt>
            <dd>$@item.GetTotal()</dd>
        }
    </dl>
    <p>Total: $@Order.GetTotal()</p>
    <button class="btn btn-warning" @onclick="PlaceOrder">Place your order</button>
}
else
{
    <p>Your cart is empty.</p>
}

@code {
    private BookstoreDb context = default!;
    private Order Order => OrderState.Order;

    protected override void OnInitialized()
    {
        context = DbFactory.CreateDbContext();
    }

    private async Task PlaceOrder()
    {
        Order.OrderDate = DateTime.Now;

        if (!Order.OrderItems.Any())
        {
            return;
        }

        foreach (var item in Order.OrderItems)
        {
            if (item.Book is null)
            {
                throw new InvalidOperationException("Cannot place an order item without a book.");
            }

            var trackedBook = context.Books.Local.FirstOrDefault(book => book.Id == item.Book.Id);
            if (trackedBook is null)
            {
                context.Attach(item.Book);
            }
            else
            {
                item.Book = trackedBook;
            }
        }

        context.Orders.Add(Order);
        await context.SaveChangesAsync();

        OrderState.ResetOrder();
        NavigationManager.NavigateTo("/myorders");
    }

    public void Dispose() => context.Dispose();
}
